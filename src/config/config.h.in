#ifndef __INIP_CONFIG_H__
#define __INIP_CONFIG_H__

/********** Section 配置宏 **********/
// 允许重复 Section
#cmakedefine INIP_ALLOW_DUPLICATE_SECTIONS
// 出现同名 Section 时，覆盖
#cmakedefine INIP_COVER_SECTION_IF_EXIST

#ifdef INIP_COVER_SECTION_IF_EXIST
#define INIP_ALLOW_DUPLICATE_SECTIONS
#endif

/********** Node 配置宏 **********/
// 允许重复 Key
#cmakedefine INIP_ALLOW_DUPLICATE_KEYS
// 出现同名 key时，覆盖
#cmakedefine INIP_COVER_KEY_IF_EXIST

#ifdef INIP_COVER_KEY_IF_EXIST
#define INIP_ALLOW_DUPLICATE_KEYS
#endif


/********** 错误处理宏 **********/
// 解析错误抛出异常
#cmakedefine INIP_THROW_EXP_IF_ERROR

/********** clear() 函数行为 **********/
// inip::Section::clear 函数是否同时清除 name
#cmakedefine INIP_SECTION_CLEAR_NAME
// inip::ini::clear 函数是否同时清除 file_name
#cmakedefine INIP_INI_CLEAR_NAME

/********** __import__ 私有扩展配置宏 **********/
// 使用 __import__ 关键字扩展
#cmakedefine INIP_USE_IMPORT
// __import__ 在导入相同节时是否覆盖
#cmakedefine INIP_IMPORT_COVER_SECTION_IF_EXIST

#ifdef INIP_IMPORT_COVER_SECTION_IF_EXIST
#define INIP_USE_IMPORT
#endif

#endif
